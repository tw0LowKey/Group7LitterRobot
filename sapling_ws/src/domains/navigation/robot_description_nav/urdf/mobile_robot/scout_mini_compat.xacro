<?xml version="1.0"?>

<robot xmlns:xacro="http://ros.org/wiki/xacro" name="scout_mini">

  <xacro:macro name="mini_wheel" params="name flip:=0.0">
    <link name="${name}_wheel_link">
      <inertial>
        <mass value="3"/>
        <origin xyz="0 0 0"/>
        <inertia ixx="0.7171" ixy="0" ixz="0" iyy="0.7171" iyz="0" izz="0.1361"/>
      </inertial>
      
      <visual>
        <origin xyz="0 0 0" rpy="${flip} 0 0" />
        <geometry>
          <mesh filename="file://$(find robot_description_nav)/meshes/scout_mini_mesh/wheel.dae" />
        </geometry>
      </visual>
      
      <collision>
        <origin xyz="0 0 0" rpy="${flip} 0 0" />
        <geometry>
          <mesh filename="file://$(find robot_description_nav)/meshes/mobile_robot/1_Link.STL" />
        </geometry>
      </collision>
      
    </link>
  </xacro:macro>
  <xacro:macro name="scout_mini_compat" params="odometry_source load_gazebo">

    <xacro:property name="track" value="0.490"/>
    <xacro:property name="wheel_radius" value="0.160"/>
    <xacro:property name="left_y_offset" value="0.0"/>

    <xacro:property name="wheel_x" value="0.2319755"/>
    <xacro:property name="wheel_y" value="0.2082515"/>
    <xacro:property name="wheel_z" value="-0.099998"/>

    <xacro:property name="base_x_size" value="0.65"/>
    <xacro:property name="base_y_size" value="0.45"/>
    <xacro:property name="base_z_size" value="0.22"/>

    <xacro:arg name="lidar_type" default="3d"/>
    <xacro:property name="lidar_type" value="$(arg lidar_type)"/>

    <xacro:if value="${lidar_type == '2d'}">
      <xacro:property name="lidar" value="lidar_2d"/>
    </xacro:if>

    <xacro:if value="${lidar_type == '3d'}">
      <xacro:property name="lidar" value="lidar_3d"/>
    </xacro:if>

    <link name="base_footprint"/>

    <joint name="base_footprint_to_base_link" type="fixed">
      <origin xyz="0 0 0.16" rpy="0 0 0"/>
      <parent link="base_footprint"/>
      <child link="base_link"/>
    </joint>

    <link name="base_link"/>

    <joint name="base_link_to_mobile_robot" type="fixed">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <parent link="base_link"/>
      <child link="mobile_robot_base_link"/>
    </joint>

    <link name="mobile_robot_base_link">
      <visual>
        <origin xyz="0 0 0" rpy="1.57 0 -1.57"/>
        <geometry>
          <mesh filename="file://$(find robot_description_nav)/meshes/scout_mini_mesh/scout_mini_base_link.dae"/>
        </geometry>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="1.57 0 -1.57"/>
        <geometry>
          <mesh filename="file://$(find robot_description_nav)/meshes/mobile_robot/scout_mini_base_link.STL"/>
        </geometry>
      </collision>
      <collision>
        <origin xyz="0 0 0.08" rpy="0 0 0"/>
        <geometry>
          <box size="${base_x_size} ${base_y_size} ${base_z_size}"/>
        </geometry>
      </collision>
    </link>

    <link name="inertial_link">
      <inertial>
        <mass value="132.3898489950015"/>
        <origin xyz="0 0 0"/>
        <inertia
          ixx="0.185196122711036"
          ixy="4.30144213829512E-08"
          ixz="5.81037523686401E-08"
          iyy="0.364893736238929"
          iyz="-0.000386720198091934"
          izz="0.223868521722778"/>
      </inertial>
    </link>

    <joint name="inertial_joint" type="fixed">
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <parent link="mobile_robot_base_link"/>
      <child link="inertial_link"/>
    </joint>

    <xacro:mini_wheel name="front_left"  flip="${pi}" />
    <xacro:mini_wheel name="rear_left"   flip="${pi}" />
    <xacro:mini_wheel name="front_right" flip="0.0" />
    <xacro:mini_wheel name="rear_right"  flip="0.0" />

    <xacro:if value="${load_gazebo}">

      <joint name="front_left_wheel" type="continuous">
        <origin rpy="1.57 0 0" xyz="${wheel_x} ${wheel_y + left_y_offset} ${wheel_z}"/>
        <parent link="mobile_robot_base_link"/>
        <child link="front_left_wheel_link"/>
        <axis xyz="0 0 -1"/>
      </joint>

      <joint name="front_right_wheel" type="continuous">
        <origin rpy="1.57 0 0" xyz="${wheel_x} ${-wheel_y} ${wheel_z}"/>
        <parent link="mobile_robot_base_link"/>
        <child link="front_right_wheel_link"/>
        <axis xyz="0 0 -1"/>
      </joint>

      <joint name="rear_left_wheel" type="continuous">
        <origin rpy="1.57 0 0" xyz="${-wheel_x} ${wheel_y + left_y_offset} ${wheel_z}"/>
        <parent link="mobile_robot_base_link"/>
        <child link="rear_left_wheel_link"/>
        <axis xyz="0 0 -1"/>
      </joint>

      <joint name="rear_right_wheel" type="continuous">
        <origin rpy="1.57 0 0" xyz="${-wheel_x} ${-wheel_y} ${wheel_z}"/>
        <parent link="mobile_robot_base_link"/>
        <child link="rear_right_wheel_link"/>
        <axis xyz="0 0 -1"/>
      </joint>

      <gazebo>
        <plugin filename="ignition-gazebo-sensors-system"
                name="ignition::gazebo::systems::Sensors">
          <render_engine>ogre2</render_engine>
        </plugin>

        <plugin filename="ignition-gazebo-imu-system"
                name="ignition::gazebo::systems::Imu" />

        <plugin filename="ignition-gazebo-joint-state-publisher-system"
                name="ignition::gazebo::systems::JointStatePublisher" />
      </gazebo>

      <gazebo>
        <plugin filename="ignition-gazebo-diff-drive-system"
                name="ignition::gazebo::systems::DiffDrive">
          <left_joint>front_left_wheel</left_joint>
          <left_joint>rear_left_wheel</left_joint>
          <right_joint>front_right_wheel</right_joint>
          <right_joint>rear_right_wheel</right_joint>

          <wheel_separation>${track}</wheel_separation>
          <wheel_radius>${wheel_radius}</wheel_radius>

          <topic>/cmd_vel</topic>

          <xacro:if value="${odometry_source == 'encoders'}">
            <odom_topic>/odom</odom_topic>
            <odom_publish_frequency>50</odom_publish_frequency>
            <tf_topic>/tf</tf_topic>
          </xacro:if>

          <frame_id>odom_leader</frame_id>
          <child_frame_id>base_footprint</child_frame_id>

          <max_linear_acceleration>2</max_linear_acceleration>
          <min_linear_acceleration>-2</min_linear_acceleration>
          <max_angular_acceleration>1</max_angular_acceleration>
          <min_angular_acceleration>-1</min_angular_acceleration>
          <max_linear_velocity>10</max_linear_velocity>
          <min_linear_velocity>-10</min_linear_velocity>
          <max_angular_velocity>1</max_angular_velocity>
          <min_angular_velocity>-1</min_angular_velocity>
        </plugin>
      </gazebo>

      <gazebo reference="imu_frame">
        <sensor name="imu_sensor" type="imu">
          <always_on>1</always_on>
          <update_rate>50</update_rate>
          <ignition_frame_id>imu_frame</ignition_frame_id>
          <visualize>true</visualize>
          <topic>/imu</topic>
        </sensor>
      </gazebo>

      <xacro:if value="${odometry_source == 'ground_truth'}">
        <gazebo>
          <plugin filename="libignition-gazebo6-odometry-publisher-system"
                  name="ignition::gazebo::systems::OdometryPublisher">
            <odom_frame>odom</odom_frame>
            <robot_base_frame>base_footprint</robot_base_frame>
            <odom_topic>/odom</odom_topic>
            <tf_topic>/tf</tf_topic>
            <dimensions>2</dimensions>
            <odom_publish_frequency>50</odom_publish_frequency>
            <gaussian_noise>0.001</gaussian_noise>
          </plugin>
        </gazebo>
      </xacro:if>

      <xacro:if value="${lidar_type == '2d'}">
        <gazebo reference="lidar_2d">
          <sensor name="gpu_lidar" type="gpu_lidar">
            <topic>/scan</topic>
            <update_rate>10</update_rate>
            <ignition_frame_id>lidar_2d</ignition_frame_id>
            <lidar>
              <scan>
                <horizontal>
                  <samples>720</samples>
                  <resolution>1</resolution>
                  <min_angle>0.0</min_angle>
                  <max_angle>${2.0*pi}</max_angle>
                </horizontal>
              </scan>
              <range>
                <min>0.55</min>
                <max>16</max>
                <resolution>0.01</resolution>
              </range>
              <noise>
                <type>gaussian</type>
                <mean>0.0</mean>
                <stddev>0.001</stddev>
              </noise>
            </lidar>
            <alwaysOn>1</alwaysOn>
            <visualize>true</visualize>
          </sensor>
        </gazebo>
      </xacro:if>

      <xacro:if value="${lidar_type == '3d'}">
        <gazebo reference="lidar_3d">
          <sensor name="gpu_lidar" type="gpu_lidar">
            <topic>/pointcloud</topic>
            <update_rate>10</update_rate>
            <ignition_frame_id>lidar_3d</ignition_frame_id>
            <lidar>
              <scan>
                <horizontal>
                  <samples>1024</samples>
                  <resolution>0.001</resolution>
                  <min_angle>-3.14</min_angle>
                  <max_angle>3.14</max_angle>
                </horizontal>
                <vertical>
                  <samples>32</samples>
                  <resolution>0.001</resolution>
                  <min_angle>-0.393</min_angle>
                  <max_angle>0.393</max_angle>
                </vertical>
              </scan>
              <range>
                <min>0.5</min>
                <max>50.0</max>
                <resolution>0.005</resolution>
              </range>
              <noise>
                <type>gaussian</type>
                <mean>0.0</mean>
                <stddev>0.001</stddev>
              </noise>
            </lidar>
            <alwaysOn>1</alwaysOn>
            <visualize>true</visualize>
          </sensor>
        </gazebo>
      </xacro:if>

    </xacro:if>

    <xacro:unless value="${load_gazebo}">

      <joint name="front_left_wheel" type="fixed">
        <origin rpy="1.57 0 0" xyz="${wheel_x} ${wheel_y + left_y_offset} ${wheel_z}"/>
        <parent link="mobile_robot_base_link"/>
        <child link="front_left_wheel_link"/>
      </joint>

      <joint name="front_right_wheel" type="fixed">
        <origin rpy="1.57 0 0" xyz="${wheel_x} ${-wheel_y} ${wheel_z}"/>
        <parent link="mobile_robot_base_link"/>
        <child link="front_right_wheel_link"/>
      </joint>

      <joint name="rear_left_wheel" type="fixed">
        <origin rpy="1.57 0 0" xyz="${-wheel_x} ${wheel_y + left_y_offset} ${wheel_z}"/>
        <parent link="mobile_robot_base_link"/>
        <child link="rear_left_wheel_link"/>
      </joint>

      <joint name="rear_right_wheel" type="fixed">
        <origin rpy="1.57 0 0" xyz="${-wheel_x} ${-wheel_y} ${wheel_z}"/>
        <parent link="mobile_robot_base_link"/>
        <child link="rear_right_wheel_link"/>
      </joint>

    </xacro:unless>

    <link name="imu_frame"/>

    <joint name="mobile_robot_to_imu" type="fixed">
      <parent link="mobile_robot_base_link"/>
      <child link="imu_frame"/>
      <origin xyz="0.0 0.0 0.08" rpy="0 0 0"/>
    </joint>

    <link name="${lidar}">
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <cylinder length="0.06" radius="0.075"/>
        </geometry>
      </collision>
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <cylinder length="0.06" radius="0.075"/>
        </geometry>
      </visual>
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="0.1"/>
        <inertia ixx="${0.1 *(3*0.075*0.075 + 0.06*0.06)/ 12}" ixy="0" ixz="0"
                 iyy="${0.1 *(3*0.075*0.075 + 0.06*0.06)/ 12}"
                 iyz="0" izz="${0.1*0.075*0.075 / 2}"/>
      </inertial>
    </link>

    <joint name="mobile_robot_to_${lidar}" type="fixed">
      <parent link="mobile_robot_base_link"/>
      <child link="${lidar}"/>
      <origin xyz="0.15 -0.0 0.15" rpy="0 0 3.14159"/>
    </joint>

  </xacro:macro>

</robot>
