<?xml version="1.0"?>

<robot xmlns:xacro="http://ros.org/wiki/xacro" name="scout_mini">

  <xacro:arg name="prefix" default="scout_2_"/>

  <xacro:property name="prefix" value="$(arg prefix)"/>

  <xacro:macro name="mini_wheel" params="name flip:=0.0">

    <link name="${prefix}${name}_wheel_link">

      <inertial>
        <mass value="3"/>
        <origin xyz="0 0 0"/>
        <inertia ixx="0.7171" ixy="0" ixz="0" iyy="0.7171" iyz="0" izz="0.1361"/>
      </inertial>

      <visual>
        <origin xyz="0 0 0" rpy="${flip} 0 0"/>
        <geometry>
          <mesh filename="file://$(find robot_description_nav)/meshes/scout_mini_mesh/wheel.dae"/>
        </geometry>
      </visual>

      <collision>
        <origin xyz="0 0 0" rpy="${flip} 0 0"/>
        <geometry>
          <mesh filename="file://$(find robot_description_nav)/meshes/scout_mini_mesh/wheel.dae"/>
        </geometry>
      </collision>

    </link>

  </xacro:macro>


  <xacro:macro name="scout_mini_compat" params="odometry_source load_gazebo">

    <xacro:property name="track" value="0.490"/>
    <xacro:property name="wheel_radius" value="0.160"/>

    <xacro:property name="wheel_x" value="0.2319755"/>
    <xacro:property name="wheel_y" value="0.2082515"/>
    <xacro:property name="wheel_z" value="-0.099998"/>

    <xacro:property name="base_x_size" value="0.65"/>
    <xacro:property name="base_y_size" value="0.45"/>
    <xacro:property name="base_z_size" value="0.22"/>

    <xacro:arg name="lidar_type" default="2d"/>


    <link name="${prefix}base_footprint"/>

    <joint name="${prefix}base_footprint_to_base_link" type="fixed">
      <origin xyz="0 0 0.16" rpy="0 0 0"/>
      <parent link="${prefix}base_footprint"/>
      <child link="${prefix}base_link"/>
    </joint>


    <link name="${prefix}base_link"/>


    <joint name="${prefix}base_link_to_mobile_robot" type="fixed">
      <parent link="${prefix}base_link"/>
      <child link="${prefix}mobile_robot_base_link"/>
    </joint>


    <link name="${prefix}mobile_robot_base_link">

      <visual>
        <origin xyz="0 0 0" rpy="1.57 0 -1.57"/>
        <geometry>
          <mesh filename="file://$(find robot_description_nav)/meshes/scout_mini_mesh/scout_mini_base_link.dae"/>
        </geometry>
      </visual>

      <collision>
        <origin xyz="0 0 0.08"/>
        <geometry>
          <box size="${base_x_size} ${base_y_size} ${base_z_size}"/>
        </geometry>
      </collision>

    </link>


    <link name="${prefix}inertial_link">

      <inertial>
        <mass value="132.38"/>
        <origin xyz="0 0 0"/>
        <inertia ixx="0.185" ixy="0" ixz="0"
                 iyy="0.364"
                 iyz="0"
                 izz="0.223"/>
      </inertial>

    </link>


    <joint name="${prefix}inertial_joint" type="fixed">
      <parent link="${prefix}mobile_robot_base_link"/>
      <child link="${prefix}inertial_link"/>
    </joint>


    <xacro:mini_wheel name="front_left" flip="${pi}"/>
    <xacro:mini_wheel name="rear_left" flip="${pi}"/>
    <xacro:mini_wheel name="front_right" flip="0"/>
    <xacro:mini_wheel name="rear_right" flip="0"/>


    <joint name="${prefix}front_left_wheel" type="continuous">
      <origin rpy="1.57 0 0" xyz="${wheel_x} ${wheel_y} ${wheel_z}"/>
      <parent link="${prefix}mobile_robot_base_link"/>
      <child link="${prefix}front_left_wheel_link"/>
      <axis xyz="0 0 -1"/>
    </joint>


    <joint name="${prefix}front_right_wheel" type="continuous">
      <origin rpy="1.57 0 0" xyz="${wheel_x} ${-wheel_y} ${wheel_z}"/>
      <parent link="${prefix}mobile_robot_base_link"/>
      <child link="${prefix}front_right_wheel_link"/>
      <axis xyz="0 0 -1"/>
    </joint>


    <joint name="${prefix}rear_left_wheel" type="continuous">
      <origin rpy="1.57 0 0" xyz="${-wheel_x} ${wheel_y} ${wheel_z}"/>
      <parent link="${prefix}mobile_robot_base_link"/>
      <child link="${prefix}rear_left_wheel_link"/>
      <axis xyz="0 0 -1"/>
    </joint>


    <joint name="${prefix}rear_right_wheel" type="continuous">
      <origin rpy="1.57 0 0" xyz="${-wheel_x} ${-wheel_y} ${wheel_z}"/>
      <parent link="${prefix}mobile_robot_base_link"/>
      <child link="${prefix}rear_right_wheel_link"/>
      <axis xyz="0 0 -1"/>
    </joint>


    <gazebo>
      <plugin filename="ignition-gazebo-diff-drive-system"
              name="ignition::gazebo::systems::DiffDrive">

        <left_joint>${prefix}front_left_wheel</left_joint>
        <left_joint>${prefix}rear_left_wheel</left_joint>

        <right_joint>${prefix}front_right_wheel</right_joint>
        <right_joint>${prefix}rear_right_wheel</right_joint>

        <wheel_separation>${track}</wheel_separation>
        <wheel_radius>${wheel_radius}</wheel_radius>

        <topic>/follower/cmd_vel</topic>
        <odom_topic>/follower/odom</odom_topic>

        <frame_id>follower/odom</frame_id>
        <child_frame_id>${prefix}base_footprint</child_frame_id>

      </plugin>
    </gazebo>


    <link name="${prefix}imu_frame"/>

    <joint name="${prefix}imu_joint" type="fixed">
      <parent link="${prefix}mobile_robot_base_link"/>
      <child link="${prefix}imu_frame"/>
      <origin xyz="0 0 0.08"/>
    </joint>


    <gazebo reference="${prefix}imu_frame">

      <sensor name="imu_sensor" type="imu">

        <always_on>true</always_on>

        <topic>/follower/imu</topic>

      </sensor>

    </gazebo>


  </xacro:macro>

</robot>