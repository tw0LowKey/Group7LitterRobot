<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="sapling">
    
    <xacro:include filename="$(find robot_description)/urdf/robot.urdf.xacro" />
    <xacro:include filename="$(find piper_description)/urdf/piper_description.xacro" />

    <joint name="scout_to_piper_joint" type="fixed">
        <parent link="mobile_robot_base_link"/> 
        <child link="arm_base_link"/>
        <origin xyz="0.13 0.0 0.1" rpy="0 0 0"/> 
    </joint>

</robot>
